FROM golang:1.26-alpine AS builder

WORKDIR /app

# 安装依赖
RUN apk add --no-cache git

# 复制go.mod和go.sum
COPY go.mod go.sum ./
RUN go mod download

# 复制源代码
COPY . .

# 编译HTTP Server
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o http-server cmd/http-server/main.go

# 最终镜像
FROM alpine:latest
WORKDIR /app
COPY --from=builder /app/http-server .
RUN mkdir -p /app/uploads
EXPOSE 8080
CMD ["./http-server"]
